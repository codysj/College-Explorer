# Shared
APP_ENV=development

# PostgreSQL
POSTGRES_DB=college_exploration
POSTGRES_USER=college
POSTGRES_PASSWORD=college
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://college:college@localhost:5432/college_exploration

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379
REDIS_ENABLED=true
CACHE_KEY_VERSION=v1
CACHE_SEARCH_TTL_SECONDS=300
CACHE_PROFILE_TTL_SECONDS=3600
CACHE_RANKING_TTL_SECONDS=300

# External services
# OPENAI_API_KEY=
